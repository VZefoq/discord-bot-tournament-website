<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= tournament.name %> - Tournament Dashboard</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header class="topbar">
    <a href="/dashboard" class="brand">🏆 Zef Tournaments</a>
    <form method="post" action="/logout"><button class="ghost" type="submit">Logout</button></form>
  </header>

  <main class="container wide">
    <% if (flash) { %>
      <div class="flash <%= flash.type %>"><%= flash.message %></div>
    <% } %>

    <section class="hero split">
      <div>
        <a href="/dashboard" class="backlink">← Back to dashboard</a>
        <h1><%= tournament.name %></h1>
        <p class="muted">Tournament ID <%= tournament.id %> · <%= participants.length %><%= tournament.max_participants ? ' / ' + tournament.max_participants : '' %> players</p>
      </div>
      <div class="hero-actions">
        <form method="post" action="/tournaments/<%= tournament.id %>/regenerate-bracket" onsubmit="return confirm('This deletes the current bracket and creates a new one from the current participants. Continue?')">
          <button class="primary" type="submit">Regenerate bracket</button>
        </form>
      </div>
    </section>

    <section class="panel">
      <h2>Details</h2>
      <form method="post" action="/tournaments/<%= tournament.id %>/details" class="grid-form">
        <label>
          Name
          <input name="name" value="<%= tournament.name %>" required maxlength="100">
        </label>
        <label>
          Status
          <select name="status">
            <% ['signup', 'open', 'running', 'completed', 'cancelled'].forEach((status) => { %>
              <option value="<%= status %>" <%= tournament.status === status ? 'selected' : '' %>><%= status %></option>
            <% }) %>
          </select>
        </label>
        <label>
          Max players
          <input name="max_participants" type="number" min="2" max="256" value="<%= tournament.max_participants || '' %>">
        </label>
        <label>
          Default region
          <input name="default_region" value="<%= tournament.default_region || '' %>" maxlength="50">
        </label>
        <label class="full">
          Description
          <textarea name="description" rows="4" maxlength="1000"><%= tournament.description || '' %></textarea>
        </label>
        <button class="primary" type="submit">Save details</button>
      </form>
    </section>

    <section class="panel" id="participants">
      <div class="section-title">
        <h2>Participants</h2>
        <span class="pill"><%= participants.length %> players</span>
      </div>

      <form method="post" action="/tournaments/<%= tournament.id %>/participants" class="grid-form compact">
        <label>
          Roblox username
          <input name="roblox_username" maxlength="50" placeholder="Roblox name" required>
        </label>
        <label>
          Discord username
          <input name="discord_username" maxlength="80" placeholder="Discord name" required>
        </label>
        <label>
          Discord ID
          <input name="discord_id" maxlength="80" placeholder="Optional, auto manual if empty">
        </label>
        <label>
          Region
          <input name="region" maxlength="50" placeholder="EU">
        </label>
        <label>
          Seed
          <input name="seed" type="number" min="1" placeholder="1">
        </label>
        <button class="primary" type="submit">Add player</button>
      </form>

      <% if (participants.length === 0) { %>
        <p class="empty">No players yet. Players can join from Discord using the Join button.</p>
      <% } else { %>
        <div class="participant-list">
          <% participants.forEach((participant) => { %>
            <div class="participant-row">
              <form method="post" action="/tournaments/<%= tournament.id %>/participants/<%= participant.id %>" class="participant-form">
                <input name="roblox_username" value="<%= participant.roblox_username %>" maxlength="50" required>
                <input name="discord_username" value="<%= participant.discord_username %>" maxlength="80" required>
                <input name="region" value="<%= participant.region %>" maxlength="50" placeholder="Region">
                <input name="seed" value="<%= participant.seed || '' %>" type="number" min="1" placeholder="Seed">
                <button type="submit">Save</button>
              </form>
              <form method="post" action="/tournaments/<%= tournament.id %>/participants/<%= participant.id %>/delete" onsubmit="return confirm('Delete this participant?')">
                <button class="danger" type="submit">Delete</button>
              </form>
            </div>
          <% }) %>
        </div>
      <% } %>
    </section>

    <section class="panel bracket-panel" id="bracket">
      <div class="section-title">
        <h2>Bracket</h2>
        <span class="pill"><%= matches.length %> matches</span>
      </div>

      <% if (matches.length === 0) { %>
        <p class="empty">No bracket generated yet. Add at least 2 participants, then click <strong>Regenerate bracket</strong>.</p>
      <% } else { %>
        <%
          const roundNumbers = Object.keys(rounds).map(Number).sort((a, b) => a - b);
          const finalRound = roundNumbers[roundNumbers.length - 1];
          const sideRounds = roundNumbers.filter((roundNumber) => roundNumber < finalRound);
          const leftRounds = sideRounds;
          const rightRounds = [...sideRounds].reverse();
          const splitRound = (roundNumber, side) => {
            const list = rounds[roundNumber] || [];
            const mid = Math.ceil(list.length / 2);
            return side === 'left' ? list.slice(0, mid) : list.slice(mid);
          };
          const roundLabel = (roundNumber) => {
            if (roundNumber === finalRound) return 'Final';
            if (roundNumber === finalRound - 1) return 'Semi final';
            if (roundNumber === finalRound - 2) return 'Quarter final';
            return `Round ${roundNumber}`;
          };
          const champion = matches.find((match) => match.round_number === finalRound && match.winner_label)?.winner_label;
        %>

        <div class="bracket-toolbar">
          <span class="muted">Visual single-elimination bracket. Use the small edit panels inside each match to change players, scores, winner, or status.</span>
          <% if (champion) { %>
            <span class="champion-pill">Champion: <strong><%= champion %></strong></span>
          <% } %>
        </div>

        <div class="playoff-bracket" style="--left-rounds:<%= leftRounds.length || 1 %>; --right-rounds:<%= rightRounds.length || 1 %>;">
          <div class="bracket-side bracket-left">
            <% leftRounds.forEach((roundNumber, index) => { %>
              <% const roundMatches = splitRound(roundNumber, 'left'); %>
              <div class="visual-round" style="--round-index:<%= index %>; --match-count:<%= roundMatches.length || 1 %>;">
                <h3><%= roundLabel(roundNumber) %></h3>
                <div class="visual-round-stack">
                  <% roundMatches.forEach((match) => { %>
                    <%- include('partials/bracket-match', { match, tournament, participants, side: 'left' }) %>
                  <% }) %>
                </div>
              </div>
            <% }) %>
          </div>

          <div class="bracket-final-column">
            <div class="bracket-title-line"></div>
            <% (rounds[finalRound] || []).forEach((match) => { %>
              <%- include('partials/bracket-match', { match, tournament, participants, side: 'final' }) %>
            <% }) %>
          </div>

          <div class="bracket-side bracket-right">
            <% rightRounds.forEach((roundNumber, index) => { %>
              <% const roundMatches = splitRound(roundNumber, 'right'); %>
              <div class="visual-round" style="--round-index:<%= index %>; --match-count:<%= roundMatches.length || 1 %>;">
                <h3><%= roundLabel(roundNumber) %></h3>
                <div class="visual-round-stack">
                  <% roundMatches.forEach((match) => { %>
                    <%- include('partials/bracket-match', { match, tournament, participants, side: 'right' }) %>
                  <% }) %>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>
    </section>
  </main>
</body>
</html>
