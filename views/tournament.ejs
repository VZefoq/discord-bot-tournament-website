<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= tournament.name %> - Tournament Dashboard</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header class="topbar">
    <a href="/dashboard" class="brand">🏆 Zef Tournaments</a>
    <form method="post" action="/logout"><button class="ghost" type="submit">Logout</button></form>
  </header>

  <main class="container wide">
    <% if (flash) { %>
      <div class="flash <%= flash.type %>"><%= flash.message %></div>
    <% } %>

    <section class="hero split challonge-hero">
      <div>
        <a href="/dashboard" class="backlink">← Back to dashboard</a>
        <p class="eyebrow">Single elimination · Challonge-style management</p>
        <h1><%= tournament.name %></h1>
        <p class="muted">Tournament ID <%= tournament.id %> · <%= participants.length %><%= tournament.max_participants ? ' / ' + tournament.max_participants : '' %> players</p>
      </div>
      <div class="hero-actions action-grid">
        <form method="post" action="/tournaments/<%= tournament.id %>/start" onsubmit="return confirm('Start/rebuild this tournament from the current players and seeds?')">
          <button class="primary" type="submit"><%= matches.length ? 'Rebuild + start' : 'Start tournament' %></button>
        </form>
        <% if (matches.length) { %>
          <form method="post" action="/tournaments/<%= tournament.id %>/reset-results" onsubmit="return confirm('Clear all scores and winners but keep the first-round bracket?')">
            <button type="submit">Reset results</button>
          </form>
          <form method="post" action="/tournaments/<%= tournament.id %>/delete-bracket" onsubmit="return confirm('Delete only the bracket? Participants stay saved.')">
            <button class="danger" type="submit">Delete bracket</button>
          </form>
        <% } %>
      </div>
    </section>

    <section class="stats-grid">
      <div class="stat-card">
        <span>Status</span>
        <strong><%= tournament.status %></strong>
      </div>
      <div class="stat-card">
        <span>Players</span>
        <strong><%= participants.length %><%= tournament.max_participants ? ' / ' + tournament.max_participants : '' %></strong>
      </div>
      <div class="stat-card">
        <span>Ready matches</span>
        <strong><%= stats.readyMatches %></strong>
      </div>
      <div class="stat-card">
        <span>Progress</span>
        <strong><%= stats.progress %>%</strong>
        <div class="progress" style="--progress:<%= stats.progress %>%"><i></i></div>
      </div>
      <% if (stats.champion) { %>
        <div class="stat-card champion-card">
          <span>Champion</span>
          <strong><%= stats.champion %></strong>
        </div>
      <% } %>
    </section>

    <section class="panel">
      <div class="section-title">
        <h2>Settings</h2>
        <span class="pill">Admin controls</span>
      </div>
      <form method="post" action="/tournaments/<%= tournament.id %>/details" class="grid-form">
        <label>
          Name
          <input name="name" value="<%= tournament.name %>" required maxlength="100">
        </label>
        <label>
          Status
          <select name="status">
            <% ['signup', 'open', 'running', 'completed', 'cancelled'].forEach((status) => { %>
              <option value="<%= status %>" <%= tournament.status === status ? 'selected' : '' %>><%= status %></option>
            <% }) %>
          </select>
        </label>
        <label>
          Max players
          <input name="max_participants" type="number" min="2" max="256" value="<%= tournament.max_participants || '' %>">
        </label>
        <label>
          Default region
          <input name="default_region" value="<%= tournament.default_region || '' %>" maxlength="50">
        </label>
        <label class="full">
          Description
          <textarea name="description" rows="4" maxlength="1000"><%= tournament.description || '' %></textarea>
        </label>
        <button class="primary" type="submit">Save settings</button>
      </form>
    </section>

    <section class="panel" id="participants">
      <div class="section-title wrap-title">
        <div>
          <h2>Participants & seeds</h2>
          <p class="muted compact-note">Like Challonge: seed players first, then start/rebuild the bracket. Seed 1 and seed 2 are placed on opposite sides.</p>
        </div>
        <div class="small-actions">
          <form method="post" action="/tournaments/<%= tournament.id %>/seed-sequential">
            <button type="submit">Auto seed</button>
          </form>
          <form method="post" action="/tournaments/<%= tournament.id %>/shuffle-seeds" onsubmit="return confirm('Randomize all seeds?')">
            <button type="submit">Shuffle seeds</button>
          </form>
        </div>
      </div>

      <form method="post" action="/tournaments/<%= tournament.id %>/participants" class="grid-form compact">
        <label>
          Roblox username
          <input name="roblox_username" maxlength="50" placeholder="Roblox name" required>
        </label>
        <label>
          Discord username
          <input name="discord_username" maxlength="80" placeholder="Discord name" required>
        </label>
        <label>
          Discord ID
          <input name="discord_id" maxlength="80" placeholder="Optional">
        </label>
        <label>
          Region
          <input name="region" maxlength="50" placeholder="EU">
        </label>
        <label>
          Seed
          <input name="seed" type="number" min="1" placeholder="1">
        </label>
        <button class="primary" type="submit">Add player</button>
      </form>

      <% if (participants.length === 0) { %>
        <p class="empty">No players yet. Players can join from Discord using the Join button.</p>
      <% } else { %>
        <div class="participant-table">
          <div class="participant-table-head">
            <span>Seed</span>
            <span>Roblox</span>
            <span>Discord</span>
            <span>Region</span>
            <span>Actions</span>
          </div>
          <% participants.forEach((participant) => { %>
            <div class="participant-table-row">
              <form method="post" action="/tournaments/<%= tournament.id %>/participants/<%= participant.id %>" class="participant-form challonge-participant-form">
                <input name="seed" value="<%= participant.seed || '' %>" type="number" min="1" placeholder="Seed">
                <input name="roblox_username" value="<%= participant.roblox_username %>" maxlength="50" required>
                <input name="discord_username" value="<%= participant.discord_username %>" maxlength="80" required>
                <input name="region" value="<%= participant.region %>" maxlength="50" placeholder="Region">
                <button type="submit">Save</button>
              </form>
              <form method="post" action="/tournaments/<%= tournament.id %>/participants/<%= participant.id %>/delete" onsubmit="return confirm('Delete this participant?')">
                <button class="danger" type="submit">Delete</button>
              </form>
            </div>
          <% }) %>
        </div>
      <% } %>
    </section>

    <section class="panel bracket-panel" id="bracket">
      <div class="section-title wrap-title">
        <div>
          <h2>Bracket</h2>
          <p class="muted compact-note">Report scores directly on a match. Clicking a winner moves them forward and clears invalid future results when you change/undo something.</p>
        </div>
        <span class="pill"><%= stats.completedMatches %> / <%= stats.totalMatches %> completed</span>
      </div>

      <% if (matches.length === 0) { %>
        <div class="empty-state-large">
          <h3>No bracket yet</h3>
          <p>Add at least 2 players, set seeds, then press <strong>Start tournament</strong>.</p>
        </div>
      <% } else { %>
        <%
          const roundNumbers = Object.keys(rounds).map(Number).sort((a, b) => a - b);
          const finalRound = roundNumbers[roundNumbers.length - 1];
          const sideRounds = roundNumbers.filter((roundNumber) => roundNumber < finalRound);
          const leftRounds = sideRounds;
          const rightRounds = [...sideRounds].reverse();
          const splitRound = (roundNumber, side) => {
            const list = rounds[roundNumber] || [];
            const mid = Math.ceil(list.length / 2);
            return side === 'left' ? list.slice(0, mid) : list.slice(mid);
          };
        %>

        <div class="bracket-toolbar challonge-toolbar">
          <div class="legend">
            <span><i class="dot ready"></i> Ready</span>
            <span><i class="dot done"></i> Done</span>
            <span><i class="dot pending"></i> Waiting</span>
          </div>
          <% if (stats.champion) { %>
            <span class="champion-pill">Champion: <strong><%= stats.champion %></strong></span>
          <% } %>
        </div>

        <div class="playoff-bracket challonge-bracket" style="--left-rounds:<%= leftRounds.length || 1 %>; --right-rounds:<%= rightRounds.length || 1 %>;">
          <div class="bracket-side bracket-left">
            <% leftRounds.forEach((roundNumber, index) => { %>
              <% const roundMatches = splitRound(roundNumber, 'left'); %>
              <div class="visual-round" style="--round-index:<%= index %>; --match-count:<%= roundMatches.length || 1 %>;">
                <h3><%= roundLabel(roundNumber, finalRound) %></h3>
                <div class="visual-round-stack">
                  <% roundMatches.forEach((match) => { %>
                    <%- include('partials/bracket-match', { match, tournament, participants, side: 'left' }) %>
                  <% }) %>
                </div>
              </div>
            <% }) %>
          </div>

          <div class="bracket-final-column">
            <div class="bracket-title-line"></div>
            <h3 class="final-heading">Final</h3>
            <% (rounds[finalRound] || []).forEach((match) => { %>
              <%- include('partials/bracket-match', { match, tournament, participants, side: 'final' }) %>
            <% }) %>
          </div>

          <div class="bracket-side bracket-right">
            <% rightRounds.forEach((roundNumber, index) => { %>
              <% const roundMatches = splitRound(roundNumber, 'right'); %>
              <div class="visual-round" style="--round-index:<%= index %>; --match-count:<%= roundMatches.length || 1 %>;">
                <h3><%= roundLabel(roundNumber, finalRound) %></h3>
                <div class="visual-round-stack">
                  <% roundMatches.forEach((match) => { %>
                    <%- include('partials/bracket-match', { match, tournament, participants, side: 'right' }) %>
                  <% }) %>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>
    </section>
  </main>
</body>
</html>
