<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= tournament.name %> - Tournament Dashboard</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header class="topbar">
    <a href="/dashboard" class="brand">Zef Tournaments</a>
    <form method="post" action="/logout"><button class="ghost" type="submit">Logout</button></form>
  </header>

  <main class="container wide">
    <% if (flash) { %>
      <div class="flash <%= flash.type %>"><%= flash.message %></div>
    <% } %>

    <section class="hero split challonge-hero">
      <div>
        <a href="/dashboard" class="backlink">Back to dashboard</a>
        <p class="eyebrow">Single elimination management</p>
        <h1 id="tournament-title"><%= tournament.name %></h1>
        <p class="muted">Tournament ID <%= tournament.id %> · <%= participants.length %><%= tournament.max_participants ? ' / ' + tournament.max_participants : '' %> players</p>
      </div>
      <div class="hero-actions action-grid">
        <% if (matches.length) { %>
          <form method="post" action="/tournaments/<%= tournament.id %>/start" onsubmit="return confirm('Start this tournament with the current bracket?')">
            <button class="primary" type="submit">Start tournament</button>
          </form>
          <form method="post" action="/tournaments/<%= tournament.id %>/regenerate-bracket" onsubmit="return confirm('Rebuild this bracket from the current players and seeds? This clears current match results.')">
            <button type="submit">Rebuild bracket</button>
          </form>
          <form method="post" action="/tournaments/<%= tournament.id %>/reset-results" onsubmit="return confirm('Clear all scores and winners but keep the first-round bracket?')">
            <button type="submit">Reset results</button>
          </form>
          <form method="post" action="/tournaments/<%= tournament.id %>/delete-bracket" onsubmit="return confirm('Delete only the bracket? Participants stay saved.')">
            <button class="danger" type="submit">Delete bracket</button>
          </form>
        <% } else { %>
          <form method="post" action="/tournaments/<%= tournament.id %>/regenerate-bracket" onsubmit="return confirm('Generate this bracket from the current players and seeds?')">
            <button class="primary" type="submit" <%= participants.length < 2 ? 'disabled' : '' %>>Generate bracket</button>
          </form>
        <% } %>
      </div>
    </section>

    <section class="stats-grid">
      <div class="stat-card">
        <span>Status</span>
        <strong id="tournament-status"><%= displayTournamentStatus(tournament.status) %></strong>
      </div>
      <div class="stat-card">
        <span>Players</span>
        <strong><%= participants.length %><%= tournament.max_participants ? ' / ' + tournament.max_participants : '' %></strong>
      </div>
      <div class="stat-card">
        <span>Ready matches</span>
        <strong><%= stats.readyMatches %></strong>
      </div>
      <div class="stat-card">
        <span>Progress</span>
        <strong><%= stats.progress %>%</strong>
        <div class="progress" style="--progress:<%= stats.progress %>%"><i></i></div>
      </div>
      <% if (stats.champion) { %>
        <div class="stat-card champion-card">
          <span>Champion</span>
          <strong><%= stats.champion %></strong>
        </div>
      <% } %>
    </section>

    <div class="tournament-tab-shell">
      <nav class="tournament-tabs" aria-label="Tournament sections">
        <a href="#settings" data-tab-link="settings">
          <span class="tab-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M12 15.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z"/><path d="M19.4 15a8.1 8.1 0 0 0 .1-1 8.1 8.1 0 0 0-.1-1l2-1.5-2-3.5-2.4 1a7.1 7.1 0 0 0-1.7-1l-.3-2.6h-4l-.3 2.6a7.1 7.1 0 0 0-1.7 1l-2.4-1-2 3.5 2 1.5a8.1 8.1 0 0 0-.1 1 8.1 8.1 0 0 0 .1 1l-2 1.5 2 3.5 2.4-1a7.1 7.1 0 0 0 1.7 1l.3 2.6h4l.3-2.6a7.1 7.1 0 0 0 1.7-1l2.4 1 2-3.5-2-1.5Z"/></svg>
          </span>
          <span>Settings</span>
        </a>
        <a href="#participants" data-tab-link="participants">
          <span class="tab-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M16 11a4 4 0 1 0-3.9-4.9"/><path d="M8 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z"/><path d="M2 21v-1a6 6 0 0 1 12 0v1"/><path d="M14.5 14.2A6 6 0 0 1 22 20v1"/></svg>
          </span>
          <span>Participants</span>
        </a>
        <a href="#bracket" data-tab-link="bracket">
          <span class="tab-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M4 5h6v4H4z"/><path d="M14 3h6v4h-6z"/><path d="M14 11h6v4h-6z"/><path d="M14 19h6v2h-6z"/><path d="M10 7h2a2 2 0 0 1 2 2v4"/><path d="M10 7h2a2 2 0 0 0 2-2"/><path d="M14 13v7"/></svg>
          </span>
          <span>Bracket</span>
        </a>
      </nav>

      <section class="panel tournament-tabs-panel">
      <section class="tab-panel" id="settings" data-tab-panel="settings">
        <div class="section-title">
          <h2>Settings</h2>
          <span class="pill" id="settings-save-state">Live save ready</span>
        </div>
        <form method="post" action="/tournaments/<%= tournament.id %>/details" class="grid-form" id="settings-form" data-live-save="true">
          <label>
            Name
            <input name="name" value="<%= tournament.name %>" required maxlength="100">
          </label>
          <label>
            Status
            <select name="status">
              <% [
                ['open', 'Open'],
                ['ongoing', 'Ongoing'],
                ['ended', 'Ended'],
              ].forEach(([status, label]) => { %>
                <option value="<%= status %>" <%= normalizeTournamentStatus(tournament.status) === status ? 'selected' : '' %>><%= label %></option>
              <% }) %>
            </select>
          </label>
          <label>
            Tournament starts
            <input name="signup_closes_at" type="datetime-local" value="<%= datetimeLocalValue(tournament.signup_closes_at) %>">
          </label>
          <label>
            Max players
            <input name="max_participants" type="number" min="2" max="256" value="<%= tournament.max_participants || '' %>">
          </label>
          <label>
            Default region
            <input name="default_region" value="<%= tournament.default_region || '' %>" maxlength="50">
          </label>
          <label class="full">
            Prize
            <textarea name="prize" rows="2" maxlength="500"><%= tournament.prize || '' %></textarea>
          </label>
          <label class="full">
            Description
            <textarea name="description" rows="4" maxlength="1000"><%= tournament.description || '' %></textarea>
          </label>
          <label class="full">
            Rules
            <textarea name="rules" rows="5" maxlength="1000"><%= tournament.rules || '' %></textarea>
          </label>
          <button class="primary" type="submit">Save settings</button>
        </form>
      </section>

      <section class="tab-panel" id="participants" data-tab-panel="participants">
        <div class="section-title wrap-title">
          <div>
            <h2>Participants & seeds</h2>
            <p class="muted compact-note">Seed players first, then start or rebuild the bracket. Seed 1 and seed 2 are placed on opposite sides.</p>
          </div>
          <div class="small-actions">
            <form method="post" action="/tournaments/<%= tournament.id %>/seed-sequential">
              <button type="submit">Auto seed</button>
            </form>
            <form method="post" action="/tournaments/<%= tournament.id %>/shuffle-seeds" onsubmit="return confirm('Randomize all seeds?')">
              <button type="submit">Shuffle seeds</button>
            </form>
          </div>
        </div>

        <form method="post" action="/tournaments/<%= tournament.id %>/participants" class="grid-form compact">
          <label>
            Roblox username
            <input name="roblox_username" maxlength="50" placeholder="Roblox name" required>
          </label>
          <label>
            Discord username
            <input name="discord_username" maxlength="80" placeholder="Discord name" required>
          </label>
          <label>
            Discord ID
            <input name="discord_id" maxlength="80" placeholder="Optional">
          </label>
          <label>
            Region
            <input name="region" maxlength="50" placeholder="EU">
          </label>
          <label>
            Seed
            <input name="seed" type="number" min="1" placeholder="1">
          </label>
          <button class="primary" type="submit">Add player</button>
        </form>

        <% if (participants.length === 0) { %>
          <p class="empty">No players yet. Players can join from Discord using the Join button.</p>
        <% } else { %>
          <div class="participant-table">
            <div class="participant-table-head">
              <span>Seed</span>
              <span>Roblox</span>
              <span>Discord</span>
              <span>Region</span>
              <span>Actions</span>
            </div>
            <% participants.forEach((participant) => { %>
              <div class="participant-table-row">
                <form method="post" action="/tournaments/<%= tournament.id %>/participants/<%= participant.id %>" class="participant-form challonge-participant-form">
                  <input name="seed" value="<%= participant.seed || '' %>" type="number" min="1" placeholder="Seed">
                  <input name="roblox_username" value="<%= participant.roblox_username %>" maxlength="50" required>
                  <input name="discord_username" value="<%= participant.discord_username %>" maxlength="80" required>
                  <input name="region" value="<%= participant.region %>" maxlength="50" placeholder="Region">
                  <button type="submit">Save</button>
                </form>
                <form method="post" action="/tournaments/<%= tournament.id %>/participants/<%= participant.id %>/delete" onsubmit="return confirm('Delete this participant?')">
                  <button class="danger" type="submit">Delete</button>
                </form>
              </div>
            <% }) %>
          </div>
        <% } %>
      </section>

      <section class="tab-panel bracket-panel" id="bracket" data-tab-panel="bracket">
        <div class="section-title wrap-title">
          <div>
            <h2>Bracket</h2>
            <p class="muted compact-note">Report scores directly on a match. The winner advances automatically from the entered scores.</p>
          </div>
          <div class="small-actions live-link-actions">
            <a class="button-link" href="<%= liveBracketUrl %>" target="_blank" rel="noopener">Open live bracket</a>
            <button type="button" data-copy-link="<%= liveBracketUrl %>">Copy live link</button>
            <span class="pill"><%= stats.completedMatches %> / <%= stats.totalMatches %> completed</span>
          </div>
        </div>
        <input class="live-link-input" value="<%= liveBracketUrl %>" readonly aria-label="Live bracket link">
        <%- include('partials/bracket-board', { tournament, participants, matches, rounds, stats, roundLabel, matchTitle, readOnly: false }) %>
      </section>
      </section>
    </div>
  </main>
  <script src="/tournament-tabs.js"></script>
  <script src="/bracket-pan.js"></script>
  <script src="/bracket-lines.js"></script>
  <script src="/bracket-scores.js"></script>
  <script src="/tournament-live.js"></script>
</body>
</html>
