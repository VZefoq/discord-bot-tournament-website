<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Tournament Dashboard</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header class="topbar">
    <a href="/dashboard" class="brand">Zef Tournaments</a>
    <form method="post" action="/logout"><button class="ghost" type="submit">Logout</button></form>
  </header>

  <main class="container">
    <% if (flash) { %>
      <div class="flash <%= flash.type %>"><%= flash.message %></div>
    <% } %>

    <section class="hero">
      <div>
        <h1>Dashboard</h1>
        <p class="muted">Edit tournaments created by the Discord bot or create one manually.</p>
      </div>
    </section>

    <section class="panel">
      <h2>Create tournament manually</h2>
      <form method="post" action="/tournaments" class="grid-form">
        <label>
          Name
          <input name="name" required maxlength="100" placeholder="Friday Roblox Cup">
        </label>
        <label>
          Max players
          <input name="max_participants" type="number" min="2" max="256" placeholder="32">
        </label>
        <label>
          Region
          <input name="default_region" maxlength="50" placeholder="EU / NA / ASIA">
        </label>
        <label>
          Tournament starts
          <input name="signup_closes_at" type="datetime-local">
        </label>
        <label>
          Prize
          <input name="prize" maxlength="500" placeholder="$50 / Robux / custom prize">
        </label>
        <label class="full">
          Description
          <textarea name="description" rows="3" maxlength="1000" placeholder="Tournament info shown in Discord."></textarea>
        </label>
        <label class="full">
          Rules
          <textarea name="rules" rows="4" maxlength="1000" placeholder="One rule per line."></textarea>
        </label>
        <button class="primary" type="submit">Create</button>
      </form>
    </section>

    <section class="panel">
      <div class="section-title">
        <h2>Tournaments</h2>
        <span class="pill"><%= tournaments.length %> total</span>
      </div>

      <% if (tournaments.length === 0) { %>
        <p class="empty">No tournaments yet. Create one with `/tournamentcreate` in Discord or use the form above.</p>
      <% } else { %>
        <div class="cards">
          <% tournaments.forEach((tournament) => { %>
            <article class="tournament-card">
              <a class="tournament-card-main" href="/tournaments/<%= tournament.id %>">
                <div>
                  <h3><%= tournament.name %></h3>
                  <p><%= tournament.description || 'No description.' %></p>
                </div>
              </a>
              <div class="card-meta">
                <span>Status: <strong><%= tournament.status %></strong></span>
                <span>Players: <strong><%= tournament.participant_count %><%= tournament.max_participants ? ' / ' + tournament.max_participants : '' %></strong></span>
                <span>Matches: <strong><%= tournament.match_count %></strong></span>
              </div>
              <form method="post" action="/tournaments/<%= tournament.id %>/delete" onsubmit="return confirm('Delete this tournament, its players, and its bracket?')">
                <button class="danger compact-danger" type="submit">Delete tournament</button>
              </form>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>
  </main>
</body>
</html>
